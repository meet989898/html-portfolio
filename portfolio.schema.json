{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meet Gandhi Portfolio Project Manifest",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "title",
      "slug",
      "subtitle",
      "cardStatus",
      "status",
      "statusLabel",
      "featuredOrder",
      "summary",
      "longSummary",
      "roleSignals",
      "techStack",
      "portfolioTags",
      "demoUrl",
      "repoUrl",
      "metrics",
      "resumeBullets",
      "visual",
      "caseStudy"
    ],
    "properties": {
      "title": { "type": "string", "minLength": 1 },
      "slug": { "type": "string", "minLength": 1 },
      "subtitle": { "type": "string", "minLength": 1 },
      "cardStatus": { "type": "string", "minLength": 1 },
      "status": { "enum": ["live", "building", "planned", "research"] },
      "statusLabel": { "type": "string", "minLength": 1 },
      "featuredOrder": { "type": "integer", "minimum": 0 },
      "summary": { "type": "string", "minLength": 1 },
      "longSummary": { "type": "string", "minLength": 1 },
      "roleSignals": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
      "techStack": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
      "portfolioTags": {
        "type": "array",
        "items": { "enum": ["ai", "ml", "data", "backend", "frontend", "research"] },
        "minItems": 1
      },
      "demoUrl": { "type": "string" },
      "repoUrl": { "type": "string" },
      "metrics": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
      "resumeBullets": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
      "visual": {
        "type": "object",
        "additionalProperties": false,
        "required": ["src", "alt", "type", "caption"],
        "properties": {
          "src": { "type": "string", "minLength": 1 },
          "alt": { "type": "string", "minLength": 1 },
          "type": { "enum": ["concept", "screenshot"] },
          "caption": { "type": "string", "minLength": 1 }
        }
      },
      "caseStudy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["problem", "approach", "outcome"],
        "properties": {
          "problem": { "type": "string", "minLength": 1 },
          "approach": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "outcome": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
        }
      }
    }
  }
}
