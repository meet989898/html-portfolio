{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meet Gandhi Portfolio Project Manifest",
  "type": "object",
  "required": [
    "title",
    "slug",
    "summary",
    "roleSignals",
    "techStack",
    "demoUrl",
    "repoUrl",
    "status",
    "metrics",
    "resumeBullets"
  ],
  "properties": {
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "summary": { "type": "string" },
    "roleSignals": { "type": "array", "items": { "type": "string" } },
    "techStack": { "type": "array", "items": { "type": "string" } },
    "demoUrl": { "type": "string" },
    "repoUrl": { "type": "string" },
    "status": { "type": "string" },
    "metrics": { "type": "array", "items": { "type": "string" } },
    "featuredAssets": { "type": "array", "items": { "type": "string" } },
    "resumeBullets": { "type": "array", "items": { "type": "string" } }
  }
}
